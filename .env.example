# ── Web EC2 — environment variables ──
NODE_ENV=production
PORT=8080

# MUST be the exact same ElastiCache/Redis instance as App EC2's REDIS_URL.
# This is what lets a session created on App EC2 (after OAuth login) be
# read and validated here on Web EC2.
REDIS_URL=redis://app-redis-cluster.xxxxxx.ng.0001.aps1.cache.amazonaws.com:6379

# MUST be byte-for-byte identical to App EC2's SESSION_SECRET, or session
# cookies signed by one server will fail validation on the other.
SESSION_SECRET=

# Optional: only needed if you want this server to proxy /api,/auth,/socket.io
# itself instead of relying purely on ALB path-based routing rules.
# APP_SERVER_URL=http://<app-ec2-private-ip>:3000
