{
  "name": "axis-underwriting-web",
  "version": "1.0.0",
  "description": "Axis Underwriting Agent - Web Tier (static frontend + auth-gated page routes). Deploys to Web EC2.",
  "main": "server.js",
  "scripts": {
    "build:css": "tailwindcss -i ./src/input.css -o ./public/styles.css --minify",
    "prestart": "npm run build:css",
    "start": "node server.js",
    "dev": "concurrently \"tailwindcss -i ./src/input.css -o ./public/styles.css --watch\" \"node server.js\"",
    "dev:css": "tailwindcss -i ./src/input.css -o ./public/styles.css --watch"
  },
  "dependencies": {
    "connect-redis": "^7.1.1",
    "cookie-parser": "^1.4.6",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-session": "^1.17.3",
    "helmet": "^7.1.0",
    "http-proxy-middleware": "^2.0.6",
    "ioredis": "^5.3.2",
    "passport": "^0.7.0"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.16",
    "concurrently": "^8.2.2",
    "postcss": "^8.4.32",
    "tailwindcss": "^3.4.19"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "license": "MIT"
}
